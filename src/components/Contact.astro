---
import ContactForm from './ContactForm';
---

<section id="contact" class="relative py-32 md:py-40">
  <!-- Background orb -->
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] pointer-events-none" aria-hidden="true">
    <div class="orb orb-cyan orb-animate-3 w-full h-full opacity-10"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16">
      <!-- Left -->
      <div class="md:col-span-5" data-animate>
        <span class="text-xs font-mono text-text-muted tracking-widest uppercase block mb-4">
          04 — Contact
        </span>
        <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl leading-tight mb-6">
          Let's <span class="gradient-text">talk</span>
        </h2>
        <p class="text-text-secondary leading-relaxed mb-8">
          Have a project in mind or need technical expertise?
          Send us a message and we'll get back to you within 24 hours.
        </p>
        <div class="space-y-3">
          <a href="mailto:contact@terminuslabs.cc" class="flex items-center gap-3 text-text-secondary hover:text-accent-cyan transition-colors duration-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span class="font-mono text-sm">contact@terminuslabs.cc</span>
          </a>
        </div>
      </div>

      <!-- Right — React form -->
      <div class="md:col-span-7" data-animate data-animate-delay="2">
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>
