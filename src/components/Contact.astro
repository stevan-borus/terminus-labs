---
---

<section id="contact" class="relative py-32 md:py-40">
  <!-- Background orb -->
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] pointer-events-none" aria-hidden="true">
    <div class="orb orb-cyan orb-animate-3 w-full h-full opacity-10"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16">
      <!-- Left -->
      <div class="md:col-span-5" data-animate>
        <span class="text-xs font-mono text-text-muted tracking-widest uppercase block mb-4">
          04 — Contact
        </span>
        <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl leading-tight mb-6">
          Let's <span class="gradient-text">talk</span>
        </h2>
        <p class="text-text-secondary leading-relaxed mb-8">
          Have a project in mind or need technical expertise?
          Send us a message and we'll get back to you within 24 hours.
        </p>
        <div class="space-y-3">
          <a href="mailto:contact@terminuslabs.com" class="flex items-center gap-3 text-text-secondary hover:text-accent-cyan transition-colors duration-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span class="font-mono text-sm">contact@terminuslabs.com</span>
          </a>
        </div>
      </div>

      <!-- Right — form -->
      <div class="md:col-span-7" data-animate data-animate-delay="2">
        <form id="contact-form" class="space-y-6">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm text-text-muted mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-surface-raised border border-border-subtle rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-all duration-300"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm text-text-muted mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-surface-raised border border-border-subtle rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-all duration-300"
                placeholder="you@company.com"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm text-text-muted mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 bg-surface-raised border border-border-subtle rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-all duration-300 resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <div class="flex items-center gap-4">
            <button
              type="submit"
              class="btn-magnetic inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-medium bg-gradient-to-r from-accent-cyan to-accent-violet text-white shadow-lg shadow-accent-violet/20 hover:shadow-accent-violet/40 transition-shadow duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span data-btn-text>Send Message</span>
              <svg data-btn-icon class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
              <!-- Spinner (hidden by default) -->
              <svg data-btn-spinner class="w-4 h-4 animate-spin hidden" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4 31.4" stroke-linecap="round" />
              </svg>
            </button>

            <!-- Status message -->
            <span data-form-status class="text-sm"></span>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btnText = document.querySelector('[data-btn-text]') as HTMLElement;
  const btnIcon = document.querySelector('[data-btn-icon]') as HTMLElement;
  const btnSpinner = document.querySelector('[data-btn-spinner]') as HTMLElement;
  const status = document.querySelector('[data-form-status]') as HTMLElement;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    btnText.textContent = 'Sending...';
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    submitBtn.disabled = true;
    status.textContent = '';
    status.className = 'text-sm';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        status.textContent = 'Message sent successfully!';
        status.className = 'text-sm text-emerald-400';
        form.reset();
      } else {
        status.textContent = result.error || 'Something went wrong.';
        status.className = 'text-sm text-red-400';
      }
    } catch {
      status.textContent = 'Network error. Please try again.';
      status.className = 'text-sm text-red-400';
    } finally {
      btnText.textContent = 'Send Message';
      btnIcon.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
      submitBtn.disabled = false;
    }
  });
</script>
