---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Gradient orbs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="orb orb-cyan orb-animate-1 w-[500px] h-[500px] -top-40 -left-40"
      data-parallax="-0.15"
    ></div>
    <div
      class="orb orb-violet orb-animate-2 w-[600px] h-[600px] top-1/4 -right-60"
      data-parallax="-0.1"
    ></div>
    <div
      class="orb orb-blue orb-animate-3 w-[400px] h-[400px] bottom-20 left-1/3"
      data-parallax="-0.2"
    ></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6 text-center">
    <!-- Tagline chip -->
    <div data-animate class="inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full border border-border-subtle/60 bg-surface-raised/50 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-cyan animate-pulse"></span>
      <span class="text-xs font-mono text-text-muted tracking-wider uppercase">Software Development & Consulting</span>
    </div>

    <!-- Headline -->
    <h1
      data-animate
      data-animate-delay="1"
      class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight mb-8"
    >
      We Build Software<br />
      <span class="gradient-text">That Drives Business</span><br />
      Forward
    </h1>

    <!-- Subtitle -->
    <p
      data-animate
      data-animate-delay="2"
      class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-12 leading-relaxed"
    >
      Terminus Labs partners with ambitious companies to design, build, and
      ship custom software solutions — from concept through production.
    </p>

    <!-- CTA -->
    <div data-animate data-animate-delay="3">
      <a
        href="#contact"
        class="btn-magnetic inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-medium bg-gradient-to-r from-accent-cyan to-accent-violet text-white shadow-lg shadow-accent-violet/20 hover:shadow-accent-violet/40 transition-shadow duration-300"
      >
        Get in Touch
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div data-animate data-animate-delay="5" class="mt-20 flex flex-col items-center gap-2 text-text-muted">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-text-muted to-transparent"></div>
    </div>
  </div>
</section>
