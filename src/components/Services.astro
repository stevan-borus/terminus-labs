---
const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    title: 'Custom Software Development',
    description: 'End-to-end development of bespoke software systems tailored to your unique business requirements — from desktop tools to cloud-native platforms.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
    title: 'Web Application Development',
    description: 'High-performance web applications built with modern frameworks. Responsive, accessible, and optimized for speed from day one.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/></svg>`,
    title: 'Technical Consulting & Architecture',
    description: 'Strategic guidance on technology decisions, system architecture, and engineering practices. We help you build the right thing the right way.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>`,
    title: 'API Design & Integration',
    description: 'Clean, well-documented APIs and seamless third-party integrations. Connect your systems with reliable, scalable interfaces.',
  },
];
---

<section id="services" class="relative py-32 md:py-40">
  <!-- Subtle orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] pointer-events-none" aria-hidden="true">
    <div class="orb orb-violet orb-animate-2 w-full h-full opacity-10"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6">
    <!-- Section header -->
    <div class="mb-16 md:mb-20" data-animate>
      <span class="text-xs font-mono text-text-muted tracking-widest uppercase block mb-4">
        02 — Services
      </span>
      <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl leading-tight max-w-lg">
        What we <span class="gradient-text">deliver</span>
      </h2>
    </div>

    <!-- Service cards grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      {services.map((service, i) => (
        <div
          data-animate
          data-animate-delay={String(i + 1)}
          class="gradient-border p-8 md:p-10 group cursor-default"
        >
          <div class="relative z-10">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-surface-overlay/50 border border-border-subtle flex items-center justify-center mb-6 text-accent-cyan group-hover:text-accent-violet transition-colors duration-500">
              <Fragment set:html={service.icon} />
            </div>

            <!-- Title -->
            <h3 class="text-xl font-semibold text-text-primary mb-3 tracking-tight">
              {service.title}
            </h3>

            <!-- Description -->
            <p class="text-text-secondary leading-relaxed">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
